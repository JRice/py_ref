# Copy to .env and fill in real values.
# Never commit .env to source control.

# Application
APP_HOST=localhost
APP_PORT=8080
APP_DEBUG=false
APP_API_KEY=dev-key-replace-me

# Database
DATABASE_URL=sqlite:///./dev.db

# External services
OPENAI_API_KEY=
STRIPE_SECRET_KEY=

# Security
SECRET_KEY=generate-with--python-m-secrets-token-hex-32
